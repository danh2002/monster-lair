{
  "name": "monster-lair",
  "version": "1.0.0",
  "description": "Production-ready gaming landing website with dark fantasy dinosaur theme",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "generate:importmap": "cross-env PAYLOAD_CONFIG_PATH=payload.importmap.config.mjs node --require ./scripts/preload-undici.cjs ./node_modules/payload/bin.js generate:importMap",
    "payload:migrate": "cross-env PAYLOAD_CONFIG_PATH=payload.migrate.config.mjs NODE_OPTIONS=\"--no-experimental-fetch -r ./scripts/preload-undici.cjs\" node ./node_modules/payload/bin.js migrate",
    "seed:admin": "node scripts/seed-admin.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "@payloadcms/db-postgres": "^3.84.1",
    "@payloadcms/next": "^3.84.1",
    "@payloadcms/plugin-seo": "^3.84.1",
    "@payloadcms/richtext-lexical": "^3.84.1",
    "@prisma/client": "^6.19.3",
    "@react-icons/all-files": "^4.1.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@tiptap/extension-code-block-lowlight": "^3.23.6",
    "@tiptap/extension-color": "^3.23.6",
    "@tiptap/extension-highlight": "^3.23.6",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-table": "^3.23.6",
    "@tiptap/extension-table-cell": "^3.23.6",
    "@tiptap/extension-table-header": "^3.23.6",
    "@tiptap/extension-table-row": "^3.23.6",
    "@tiptap/extension-text-align": "^3.23.6",
    "@tiptap/extension-text-style": "^3.23.6",
    "@tiptap/extension-underline": "^3.23.6",
    "@tiptap/extension-youtube": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@vercel/analytics": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.39.0",
    "lowlight": "^3.3.0",
