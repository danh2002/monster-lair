    "@types/react-dom": "^19.2.3",
    "@types/styled-components": "^5.1.33",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "prettier": "^3.1.1",
    "typescript": "^5.3.3",
    "undici": "5.28.4"
