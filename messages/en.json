      "items": [
        {
          "cat": "account",
          "q": "How do I recover my account password?",
          "a": "Go to the login page and click <strong>\"Forgot password?\"</strong>. Enter your registered phone number or email. You will receive an OTP within 2 minutes. Enter the code and set a new password. If you don't receive the code, check your spam folder or contact support directly."
        },
        {
          "cat": "account",
          "q": "My account is locked — what should I do?",
          "a": "Accounts may be locked due to terms of service violations or unusual activity. Please contact our support team via <strong>support@daokhunglong.vn</strong> or Discord for review and resolution within 48 business hours."
        },
        {
          "cat": "payment",
          "q": "What payment methods are supported?",
          "a": "Dinosaur Island currently supports: <strong>Domestic ATM cards, Visa/Mastercard, MoMo, ZaloPay, VNPay, and phone top-up cards (Viettel, Vinaphone, Mobifone)</strong>. We continuously add new payment methods."
        },
        {
          "cat": "payment",
          "q": "Transaction successful but coins not received — what should I do?",
          "a": "Coins are usually credited instantly. In rare cases, processing may take up to <strong>15 minutes</strong>. If you haven't received them after 30 minutes, check your order history. If the transaction shows \"Pending\", wait a bit longer. If \"Rejected\", contact support with your order ID."
        },
        {
          "cat": "game",
          "q": "What is the Battle Arena and how do I join?",
          "a": "The Battle Arena is a large-scale PvP event where the <strong>Dragon</strong> and <strong>Immortal</strong> factions face off. Each season lasts 10 days. Join by registering in-game, earn points through battles, and climb the leaderboard to earn exclusive coin rewards."
        },
        {
          "cat": "game",
          "q": "How do I download the game on PC?",
          "a": "Click the <strong>\"Download Free\"</strong> button on the homepage. Choose the right version (Windows 10/11 64-bit, min 8GB RAM, NVIDIA GTX 1060 or above). The installer is around 35GB. Once downloaded, run the installer and follow the instructions."
        },
        {
          "cat": "tech",
          "q": "The game is lagging — how do I fix it?",
          "a": "Try these steps: <strong>1.</strong> Lower graphics quality in Settings. <strong>2.</strong> Close background applications. <strong>3.</strong> Check your network and switch to the nearest server. <strong>4.</strong> Update your GPU driver. <strong>5.</strong> Clear the game cache in the install folder."
        },
        {
          "cat": "tech",
          "q": "What are the minimum PC requirements?",
          "a": "<strong>Minimum:</strong> Windows 10 64-bit, Intel i5-8400 / AMD Ryzen 5 2600, 8GB RAM, NVIDIA GTX 1060 6GB, 50GB SSD free.<br><br><strong>Recommended:</strong> Intel i7-10700K / Ryzen 7 5800X, 16GB RAM, RTX 3070 / RX 6700 XT for best experience at 1080p 60fps."
        }
      ]
    },
